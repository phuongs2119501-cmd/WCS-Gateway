{
  "$schema": "./db500-keys.schema.json",
  "meta": {
    "version": 3,
    "db": 500,
    "minLengthBytes": 86,
    "description": "Canonical DB500 memory map for the WCS automatic-warehouse PLCs. SINGLE SOURCE OF TRUTH for every PLC offset the Gateway reads/writes. v3 (2026-06-21): offsets re-pointed to the REAL, hardware-verified layout collected from the live PLC connection (cross-checked against main's Data Mapping PLC). Both PLC1 and PLC2 expose the SAME DB500 layout; identity comes from which connector (PLC1 vs PLC2), not the address.",
    "endianness": "big-endian (S7)",
    "plcEndpoints": {
      "plc1": "192.168.39.10:102 (Rack 0, Slot 1, S71200)",
      "plc2": "192.168.39.13:102 (Rack 0, Slot 1, S71200)"
    },
    "typeNotes": "S7 'Int' = signed 16-bit. Gateway READS DBW words as ushort and WRITES them as Int16 (short); harmless for the small non-negative ranges used. 'Char' fields are DBB bytes read as ASCII. Override path: set env WCS_DB500_KEYS to point at an alternate JSON of this shape.",
    "v3Changes": "Shuttle-state, barcode, done, system-state, positions, gate and heartbeat regions shifted +4..+8 bytes vs v2 to match the real PLC. Added: reqAutoRun/reqStop command bits, full crane-2 state+position block, plcFail handshake, gateExport, directionBlock2. Key names from v2 are preserved (only addresses changed) so existing services compile unchanged; new real-PLC fields are added as new keys."
  },
  "regions": {
    "command":     "0-14  : commands + target location (Gateway writes)",
    "crane1State": "16-18 : crane-1 state (Gateway reads)",
    "crane2State": "20-22 : crane-2 state (Gateway reads)",
    "shuttle1State":"24-28 : shuttle-1 state + battery/PIN (Gateway reads)",
    "shuttle2State":"30-34 : shuttle-2 state + battery/PIN (Gateway reads)",
    "barcode":     "36-50 : 14-char barcode (read) + OK/NG result flags (readwrite)",
    "result":      "52    : job done/fail handshake (Gateway reads)",
    "systemState": "54-56 : Auto/Running/Stop/Error + error code (Gateway reads)",
    "positions":   "58-76 : crane-1/2 + shuttle-1/2 live positions (Gateway reads)",
    "gate":        "78-80 : import/export gate codes (Gateway reads)",
    "heartbeat":   "82    : WCS(PC)-alive heartbeat (Gateway writes true every loop while connected)",
    "direction":   "84    : direction block 2 (Gateway reads)"
  },
  "fields": [
    { "key": "reqImportPallet",   "address": "DB500.DBX0.0", "type": "Bool", "access": "write", "region": "command", "meaning": "Command bit: Import/Inbound pallet (commandType=1)." },
    { "key": "reqExportPallet",   "address": "DB500.DBX0.1", "type": "Bool", "access": "write", "region": "command", "meaning": "Command bit: Export pallet (commandType=2)." },
    { "key": "reqTransferPallet", "address": "DB500.DBX0.2", "type": "Bool", "access": "write", "region": "command", "meaning": "Command bit: Transfer pallet (commandType=3)." },
    { "key": "reqAutoRun",        "address": "DB500.DBX0.3", "type": "Bool", "access": "write", "region": "command", "meaning": "System control: request Auto-Run." },
    { "key": "reqStop",           "address": "DB500.DBX0.4", "type": "Bool", "access": "write", "region": "command", "meaning": "System control: request Stop." },
    { "key": "modeCraneShuttle",  "address": "DB500.DBW2",   "type": "Int", "access": "write", "region": "command", "meaning": "Routing/selected mode. 0=none, 1=PLC1, 2=PLC2. Written to BOTH PLCs." },
    { "key": "xin",  "address": "DB500.DBW4",  "type": "Int", "access": "write", "region": "command", "meaning": "Source infeed column (X)." },
    { "key": "zin",  "address": "DB500.DBW6",  "type": "Int", "access": "write", "region": "command", "meaning": "Source infeed level (Z)." },
    { "key": "bin",  "address": "DB500.DBW8",  "type": "Int", "access": "write", "region": "command", "meaning": "Source infeed row (B). Routing: 1=PLC1 side, 3=PLC2 side, 2=shared (decided by Xin 1-13=>PLC1, 14-26=>PLC2)." },
    { "key": "xout", "address": "DB500.DBW10", "type": "Int", "access": "write", "region": "command", "meaning": "Destination column (X)." },
    { "key": "zout", "address": "DB500.DBW12", "type": "Int", "access": "write", "region": "command", "meaning": "Destination level (Z)." },
    { "key": "bout", "address": "DB500.DBW14", "type": "Int", "access": "write", "region": "command", "meaning": "Destination row (B)." },

    { "key": "craneFree",      "address": "DB500.DBX16.0", "type": "Bool", "access": "read", "region": "crane1State", "meaning": "Crane-1 idle/free." },
    { "key": "craneBusy",      "address": "DB500.DBX16.1", "type": "Bool", "access": "read", "region": "crane1State", "meaning": "Crane-1 executing a task." },
    { "key": "craneError",     "address": "DB500.DBX16.2", "type": "Bool", "access": "read", "region": "crane1State", "meaning": "Crane-1 fault flag." },
    { "key": "craneErrorCode", "address": "DB500.DBW18",   "type": "Int",  "access": "read", "region": "crane1State", "meaning": "Crane-1 error code (0 = no error)." },

    { "key": "crane2Free",      "address": "DB500.DBX20.0", "type": "Bool", "access": "read", "region": "crane2State", "meaning": "Crane-2 idle/free." },
    { "key": "crane2Busy",      "address": "DB500.DBX20.1", "type": "Bool", "access": "read", "region": "crane2State", "meaning": "Crane-2 executing a task." },
    { "key": "crane2Error",     "address": "DB500.DBX20.2", "type": "Bool", "access": "read", "region": "crane2State", "meaning": "Crane-2 fault flag." },
    { "key": "crane2ErrorCode", "address": "DB500.DBW22",   "type": "Int",  "access": "read", "region": "crane2State", "meaning": "Crane-2 error code (0 = no error)." },

    { "key": "shuttle1Free",      "address": "DB500.DBX24.0", "type": "Bool", "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 idle/free." },
    { "key": "shuttle1Busy",      "address": "DB500.DBX24.1", "type": "Bool", "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 executing a task." },
    { "key": "shuttle1Error",     "address": "DB500.DBX24.2", "type": "Bool", "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 fault flag." },
    { "key": "shuttle1ErrorCode", "address": "DB500.DBW26",   "type": "Int",  "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 error code." },
    { "key": "shuttle1Battery",   "address": "DB500.DBW28",   "type": "Int",  "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 battery/PIN percentage." },

    { "key": "shuttle2Free",      "address": "DB500.DBX30.0", "type": "Bool", "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 idle/free." },
    { "key": "shuttle2Busy",      "address": "DB500.DBX30.1", "type": "Bool", "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 executing a task." },
    { "key": "shuttle2Error",     "address": "DB500.DBX30.2", "type": "Bool", "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 fault flag." },
    { "key": "shuttle2ErrorCode", "address": "DB500.DBW32",   "type": "Int",  "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 error code." },
    { "key": "shuttle2Battery",   "address": "DB500.DBW34",   "type": "Int",  "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 battery/PIN percentage." },

    { "key": "barcode", "address": "DB500.DBB36", "type": "Char", "length": 14, "access": "read", "region": "barcode", "meaning": "14-char pallet barcode, DBB36..DBB49 read as ASCII then trimmed. PLC self-reads it; Gateway exposes the string." },
    { "key": "barcodeOk", "address": "DB500.DBX50.0", "type": "Bool", "access": "readwrite", "region": "barcode", "meaning": "Barcode-valid result. Gateway writes after validation; also read back." },
    { "key": "barcodeNg", "address": "DB500.DBX50.1", "type": "Bool", "access": "readwrite", "region": "barcode", "meaning": "Barcode-invalid result. Gateway writes after validation; also read back." },

    { "key": "plcDone", "address": "DB500.DBX52.0", "type": "Bool", "access": "read", "region": "result", "meaning": "PLC job-complete handshake. Gateway polls; on true it clears the command bit and finishes the job." },
    { "key": "plcFail", "address": "DB500.DBX52.1", "type": "Bool", "access": "read", "region": "result", "meaning": "PLC job-failed handshake." },

    { "key": "sysAuto",      "address": "DB500.DBX54.0", "type": "Bool", "access": "read", "region": "systemState", "meaning": "Auto (true) vs Manual (false) mode." },
    { "key": "sysRunning",   "address": "DB500.DBX54.1", "type": "Bool", "access": "read", "region": "systemState", "meaning": "System running." },
    { "key": "sysStop",      "address": "DB500.DBX54.2", "type": "Bool", "access": "read", "region": "systemState", "meaning": "System stopped." },
    { "key": "sysError",     "address": "DB500.DBX54.3", "type": "Bool", "access": "read", "region": "systemState", "meaning": "System error flag." },
    { "key": "sysErrorCode", "address": "DB500.DBW56",   "type": "Int",  "access": "read", "region": "systemState", "meaning": "System error code." },

    { "key": "craneX",    "address": "DB500.DBW58", "type": "Int", "access": "read", "region": "positions", "meaning": "Crane-1 live position X (column)." },
    { "key": "craneZ",    "address": "DB500.DBW60", "type": "Int", "access": "read", "region": "positions", "meaning": "Crane-1 live position Z (level)." },
    { "key": "crane2X",   "address": "DB500.DBW62", "type": "Int", "access": "read", "region": "positions", "meaning": "Crane-2 live position X (column)." },
    { "key": "crane2Z",   "address": "DB500.DBW64", "type": "Int", "access": "read", "region": "positions", "meaning": "Crane-2 live position Z (level)." },
    { "key": "shuttle1X", "address": "DB500.DBW66", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-1 live position X." },
    { "key": "shuttle1Z", "address": "DB500.DBW68", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-1 live position Z." },
    { "key": "shuttle1B", "address": "DB500.DBW70", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-1 live position B (row/side)." },
    { "key": "shuttle2X", "address": "DB500.DBW72", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-2 live position X." },
    { "key": "shuttle2Z", "address": "DB500.DBW74", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-2 live position Z." },
    { "key": "shuttle2B", "address": "DB500.DBW76", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-2 live position B (row/side)." },

    { "key": "gate",       "address": "DB500.DBW78", "type": "Int", "access": "read", "region": "gate", "meaning": "Import gate/cong code (PLC1 gates 1,3 / PLC2 gates 2,4)." },
    { "key": "gateExport", "address": "DB500.DBW80", "type": "Int", "access": "read", "region": "gate", "meaning": "Export gate/cong code." },

    { "key": "wcsHeartbeat", "address": "DB500.DBX82.0", "type": "Bool", "access": "write", "region": "heartbeat", "meaning": "WCS(PC)-alive heartbeat. Worker writes true every 50ms loop to BOTH PLCs while connected; PLC watchdog uses it to detect a dead/disconnected Gateway. The simulator MUST accept this write; real PLC monitors it." },

    { "key": "directionBlock2", "address": "DB500.DBW84", "type": "Int", "access": "read", "region": "direction", "meaning": "Direction block 2 (real-PLC field; routing/direction hint per block)." }
  ],
  "perConnectorUsage": {
    "note": "The map above is the canonical per-PLC DB500 layout (PLC1 and PLC2 are byte-identical). How the Gateway binds slots to logical devices:",
    "crane1": "read from PLC1 connector @ DBX16.x / DBW18 / pos DBW58/60",
    "crane2": "read from the same connector @ DBX20.x / DBW22 / pos DBW62/64",
    "shuttle1": "read @ DBX24.x / DBW26 / battery DBW28 / pos DBW66/68/70",
    "shuttle2": "read @ DBX30.x / DBW32 / battery DBW34 / pos DBW72/74/76",
    "command": "written to BOTH PLC1 and PLC2 connectors (offsets 0-14); the active PLC is chosen by Bin/Xin routing.",
    "acceptedKey": "NOT a DB500 field. The X-Idempotency-Key dedupe value lives in the Gateway layer (SystemState), surfaced on /status per crane. PLC DB space is too tight to hold it."
  }
}
