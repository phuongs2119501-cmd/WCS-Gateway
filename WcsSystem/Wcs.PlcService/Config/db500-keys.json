{
  "$schema": "./db500-keys.schema.json",
  "meta": {
    "version": 2,
    "db": 500,
    "minLengthBytes": 76,
    "description": "Canonical DB500 memory map for the WCS automatic-warehouse PLCs. This file is the SINGLE SOURCE OF TRUTH for every PLC offset the Gateway reads/writes. Both PLC1 and PLC2 expose the SAME DB500 layout; identity comes from which connector (PLC1 vs PLC2), not the address.",
    "endianness": "big-endian (S7)",
    "plcEndpoints": {
      "plc1": "192.168.39.10:102 (Rack 0, Slot 1, S71200)",
      "plc2": "192.168.39.13:102 (Rack 0, Slot 1, S71200)"
    },
    "typeNotes": "S7 'Int' = signed 16-bit. Gateway code currently READS DBW words as ushort and WRITES them as Int16 (short); harmless for the small non-negative ranges used. 'Char' fields are DBB bytes read as ASCII. Override path: set env WCS_DB500_KEYS to point at an alternate JSON of this shape."
  },
  "regions": {
    "command":   "0-14  : commands + target location (Gateway writes)",
    "craneState":"16-18 : crane state (Gateway reads)",
    "shuttle1State":"20-24 : shuttle-1 state + battery (Gateway reads)",
    "shuttle2State":"26-30 : shuttle-2 state + battery (Gateway reads)",
    "barcode":   "32-46 : 14-char barcode (read) + OK/NG result flags (write)",
    "done":      "48    : job-complete handshake (Gateway reads)",
    "systemState":"50-52 : Auto/Running/Stop/Error + error code (Gateway reads)",
    "positions": "54-70 : crane + shuttle live positions, gate (Gateway reads)",
    "heartbeat": "74    : WCS(PC)-alive heartbeat (Gateway writes true every loop while connected)"
  },
  "fields": [
    { "key": "reqImportPallet",   "address": "DB500.DBX0.0",  "type": "Bool", "access": "write", "region": "command", "meaning": "Command bit: Import/Inbound pallet (commandType=1)." },
    { "key": "reqExportPallet",   "address": "DB500.DBX0.1",  "type": "Bool", "access": "write", "region": "command", "meaning": "Command bit: Export pallet (commandType=2)." },
    { "key": "reqTransferPallet", "address": "DB500.DBX0.2",  "type": "Bool", "access": "write", "region": "command", "meaning": "Command bit: Transfer pallet (commandType=3)." },
    { "key": "modeCraneShuttle",  "address": "DB500.DBW2",   "type": "Int", "access": "write", "region": "command", "meaning": "Routing/selected mode. 0=none, 1=PLC1, 2=PLC2. Written to BOTH PLCs." },
    { "key": "xin",  "address": "DB500.DBW4",  "type": "Int", "access": "write", "region": "command", "meaning": "Source infeed column (X)." },
    { "key": "zin",  "address": "DB500.DBW6",  "type": "Int", "access": "write", "region": "command", "meaning": "Source infeed level (Z)." },
    { "key": "bin",  "address": "DB500.DBW8",  "type": "Int", "access": "write", "region": "command", "meaning": "Source infeed row (B). Routing: 1=PLC1 side, 3=PLC2 side, 2=shared (decided by Xin 1-13=>PLC1, 14-26=>PLC2)." },
    { "key": "xout", "address": "DB500.DBW10", "type": "Int", "access": "write", "region": "command", "meaning": "Destination column (X)." },
    { "key": "zout", "address": "DB500.DBW12", "type": "Int", "access": "write", "region": "command", "meaning": "Destination level (Z)." },
    { "key": "bout", "address": "DB500.DBW14", "type": "Int", "access": "write", "region": "command", "meaning": "Destination row (B)." },

    { "key": "craneFree",      "address": "DB500.DBX16.0", "type": "Bool", "access": "read", "region": "craneState", "meaning": "Crane idle/free." },
    { "key": "craneBusy",      "address": "DB500.DBX16.1", "type": "Bool", "access": "read", "region": "craneState", "meaning": "Crane executing a task." },
    { "key": "craneError",     "address": "DB500.DBX16.2", "type": "Bool", "access": "read", "region": "craneState", "meaning": "Crane fault flag." },
    { "key": "craneErrorCode", "address": "DB500.DBW18",   "type": "Int",  "access": "read", "region": "craneState", "meaning": "Crane error code (0 = no error)." },

    { "key": "shuttle1Free",      "address": "DB500.DBX20.0", "type": "Bool", "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 idle/free." },
    { "key": "shuttle1Busy",      "address": "DB500.DBX20.1", "type": "Bool", "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 executing a task." },
    { "key": "shuttle1Error",     "address": "DB500.DBX20.2", "type": "Bool", "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 fault flag." },
    { "key": "shuttle1ErrorCode", "address": "DB500.DBW22",   "type": "Int",  "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 error code." },
    { "key": "shuttle1Battery",   "address": "DB500.DBW24",   "type": "Int",  "access": "read", "region": "shuttle1State", "meaning": "Shuttle-1 battery percentage." },

    { "key": "shuttle2Free",      "address": "DB500.DBX26.0", "type": "Bool", "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 idle/free." },
    { "key": "shuttle2Busy",      "address": "DB500.DBX26.1", "type": "Bool", "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 executing a task." },
    { "key": "shuttle2Error",     "address": "DB500.DBX26.2", "type": "Bool", "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 fault flag." },
    { "key": "shuttle2ErrorCode", "address": "DB500.DBW28",   "type": "Int",  "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 error code." },
    { "key": "shuttle2Battery",   "address": "DB500.DBW30",   "type": "Int",  "access": "read", "region": "shuttle2State", "meaning": "Shuttle-2 battery percentage." },

    { "key": "barcode", "address": "DB500.DBB32", "type": "Char", "length": 14, "access": "read", "region": "barcode", "meaning": "14-char pallet barcode, DBB32..DBB45 read as ASCII then trimmed. PLC self-reads it; Gateway exposes the string." },
    { "key": "barcodeOk", "address": "DB500.DBX46.0", "type": "Bool", "access": "readwrite", "region": "barcode", "meaning": "Barcode-valid result. Gateway writes after validation; also read back." },
    { "key": "barcodeNg", "address": "DB500.DBX46.1", "type": "Bool", "access": "readwrite", "region": "barcode", "meaning": "Barcode-invalid result. Gateway writes after validation; also read back." },

    { "key": "plcDone", "address": "DB500.DBX48.0", "type": "Bool", "access": "read", "region": "done", "meaning": "PLC job-complete handshake. Gateway polls; on true it clears the command bit and finishes the job." },

    { "key": "sysAuto",      "address": "DB500.DBX50.0", "type": "Bool", "access": "read", "region": "systemState", "meaning": "Auto (true) vs Manual (false) mode." },
    { "key": "sysRunning",   "address": "DB500.DBX50.1", "type": "Bool", "access": "read", "region": "systemState", "meaning": "System running." },
    { "key": "sysStop",      "address": "DB500.DBX50.2", "type": "Bool", "access": "read", "region": "systemState", "meaning": "System stopped." },
    { "key": "sysError",     "address": "DB500.DBX50.3", "type": "Bool", "access": "read", "region": "systemState", "meaning": "System error flag." },
    { "key": "sysErrorCode", "address": "DB500.DBW52",   "type": "Int",  "access": "read", "region": "systemState", "meaning": "System error code." },

    { "key": "craneX",    "address": "DB500.DBW54", "type": "Int", "access": "read", "region": "positions", "meaning": "Crane live position X (column)." },
    { "key": "craneZ",    "address": "DB500.DBW56", "type": "Int", "access": "read", "region": "positions", "meaning": "Crane live position Z (level)." },
    { "key": "shuttle1X", "address": "DB500.DBW58", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-1 live position X." },
    { "key": "shuttle1Z", "address": "DB500.DBW60", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-1 live position Z." },
    { "key": "shuttle1B", "address": "DB500.DBW62", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-1 live position B (row/side)." },
    { "key": "shuttle2X", "address": "DB500.DBW64", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-2 live position X." },
    { "key": "shuttle2Z", "address": "DB500.DBW66", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-2 live position Z." },
    { "key": "shuttle2B", "address": "DB500.DBW68", "type": "Int", "access": "read", "region": "positions", "meaning": "Shuttle-2 live position B (row/side)." },
    { "key": "gate",      "address": "DB500.DBW70", "type": "Int", "access": "read", "region": "positions", "meaning": "Current gate/cong code (PLC1 gates 1,3 / PLC2 gates 2,4)." },

    { "key": "wcsHeartbeat", "address": "DB500.DBX74.0", "type": "Bool", "access": "write", "region": "heartbeat", "meaning": "WCS(PC)-alive heartbeat. Worker writes true every 50ms loop to BOTH PLCs while connected; PLC watchdog uses it to detect a dead/disconnected Gateway. The simulator MUST accept this write; real PLC monitors it." }
  ],
  "perConnectorUsage": {
    "note": "The map above is the canonical per-PLC DB500 layout. How the Gateway binds slots to logical devices:",
    "crane1": "read from PLC1 connector @ DBX16.x / DBW18 / DBW54 / DBW56",
    "crane2": "read from PLC2 connector @ the SAME offsets (16/18/54/56)",
    "shuttle1": "read from PLC1 connector @ DBX20.x / DBW22 / DBW24 and position DBW58/60/62",
    "shuttle2": "read from PLC2 connector @ DBX26.x / DBW28 / DBW30 and position DBW64/66/68",
    "command": "written to BOTH PLC1 and PLC2 connectors (offsets 0-14); the active PLC is chosen by Bin/Xin routing.",
    "acceptedKey": "NOT a DB500 field. The X-Idempotency-Key dedupe value lives in the Gateway layer (SystemState), surfaced on /status per crane. PLC DB space is too tight to hold it. See contract.crane-contention-lock + contract.inbound-location-send."
  }
}
