@{
    Layout = "_Layout";
}

<!-- ═══════════════════════════════════════════════════════ -->
<!--  HEADER: Title + PLC Status                            -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="top-header">
    <h2 class="page-title">⚙ WCS CONTROL</h2>
    <div class="plc-row">
        <div class="plc-chip">
            <div class="dot off" id="dot1"></div>
            <span>PLC 1</span>
            <span id="plc1-text" class="plc-text">--</span>
        </div>
        <div class="plc-chip">
            <div class="dot off" id="dot2"></div>
            <span>PLC 2</span>
            <span id="plc2-text" class="plc-text">--</span>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!--  DATA GRID                                             -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="mon-grid">

    <!-- BARCODE -->
    <div class="mon-card">
        <div class="mon-title">📦 Barcode</div>
        <div class="mon-row">
            <span class="mon-label">PLC 1</span>
            <div style="display: flex; align-items: center; gap: 8px;">
                <span class="mon-value barcode-plc1" id="barcode1">--</span>
                <span id="barcode1-status"></span>
            </div>
        </div>
        <div class="mon-row">
            <span class="mon-label">PLC 2</span>
            <div style="display: flex; align-items: center; gap: 8px;">
                <span class="mon-value barcode-plc2" id="barcode2">--</span>
                <span id="barcode2-status"></span>
            </div>
        </div>
    </div>

    <!-- CRANE 1 -->
    <div class="mon-card">
        <div class="mon-title">🏗 Crane 1</div>
        <div class="mon-row"><span class="mon-label">X</span><span class="mon-value" id="crane1-x">--</span></div>
        <div class="mon-row"><span class="mon-label">Z</span><span class="mon-value" id="crane1-z">--</span></div>
        <div class="mon-row"><span class="mon-label">Trạng thái</span><span id="crane1-state">--</span></div>
        <div class="mon-row"><span class="mon-label">Lỗi</span><span class="mon-value" id="crane1-err">--</span></div>
    </div>

    <!-- CRANE 2 -->
    <div class="mon-card">
        <div class="mon-title">🏗 Crane 2</div>
        <div class="mon-row"><span class="mon-label">X</span><span class="mon-value" id="crane2-x">--</span></div>
        <div class="mon-row"><span class="mon-label">Z</span><span class="mon-value" id="crane2-z">--</span></div>
        <div class="mon-row"><span class="mon-label">Trạng thái</span><span id="crane2-state">--</span></div>
        <div class="mon-row"><span class="mon-label">Lỗi</span><span class="mon-value" id="crane2-err">--</span></div>
    </div>

    <!-- SHUTTLE 1 -->
    <div class="mon-card">
        <div class="mon-title">🚗 Shuttle 1</div>
        <div class="mon-row"><span class="mon-label">X</span><span class="mon-value" id="shuttle1-x">--</span></div>
        <div class="mon-row"><span class="mon-label">Z</span><span class="mon-value" id="shuttle1-z">--</span></div>
        <div class="mon-row"><span class="mon-label">B</span><span class="mon-value" id="shuttle1-b">--</span></div>
        <div class="mon-row"><span class="mon-label">Trạng thái</span><span id="shuttle1-state">--</span></div>
        <div class="mon-row"><span class="mon-label">Pin</span><span class="mon-value" id="shuttle1-pin">--</span></div>
    </div>

    <!-- SHUTTLE 2 -->
    <div class="mon-card">
        <div class="mon-title">🚗 Shuttle 2</div>
        <div class="mon-row"><span class="mon-label">X</span><span class="mon-value" id="shuttle2-x">--</span></div>
        <div class="mon-row"><span class="mon-label">Z</span><span class="mon-value" id="shuttle2-z">--</span></div>
        <div class="mon-row"><span class="mon-label">B</span><span class="mon-value" id="shuttle2-b">--</span></div>
        <div class="mon-row"><span class="mon-label">Trạng thái</span><span id="shuttle2-state">--</span></div>
        <div class="mon-row"><span class="mon-label">Pin</span><span class="mon-value" id="shuttle2-pin">--</span></div>
    </div>

</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!--  SYSTEM STATE + CONTROLS (3 cột ngang nhau)           -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="section-title">⚙️ SYSTEM STATE &amp; CONTROLS</div>
<div class="bottom-grid">

    <!-- SYSTEM STATE PLC 1 -->
    <div class="mon-card">
        <div class="mon-title">⚙️ System State — PLC 1</div>
        <div class="mon-row"><span class="mon-label">Mode</span><span id="sys1-mode">--</span></div>
        <div class="mon-row"><span class="mon-label">Running</span><span id="sys1-run">--</span></div>
        <div class="mon-row"><span class="mon-label">Stop</span><span id="sys1-stop">--</span></div>
        <div class="mon-row"><span class="mon-label">Error</span><span id="sys1-err">--</span></div>
        <div class="mon-row"><span class="mon-label">Error Code</span><span class="mon-value" id="sys1-code">--</span></div>
    </div>

    <!-- SYSTEM STATE PLC 2 -->
    <div class="mon-card">
        <div class="mon-title">⚙️ System State — PLC 2</div>
        <div class="mon-row"><span class="mon-label">Mode</span><span id="sys2-mode">--</span></div>
        <div class="mon-row"><span class="mon-label">Running</span><span id="sys2-run">--</span></div>
        <div class="mon-row"><span class="mon-label">Stop</span><span id="sys2-stop">--</span></div>
        <div class="mon-row"><span class="mon-label">Error</span><span id="sys2-err">--</span></div>
        <div class="mon-row"><span class="mon-label">Error Code</span><span class="mon-value" id="sys2-code">--</span></div>
    </div>

    <!-- LOCATION INPUT (READ-ONLY) -->
    <div class="mon-card">
        <div class="mon-title">📍 Last Location Cmd</div>
        <div class="cmd-row">
            <span class="mon-label">COMMAND</span>
            <span class="mon-value" id="disp-CommandType" style="color:#22c55e">--</span>
        </div>
        <div class="loc-table">
            <div class="loc-row loc-header">
                <span></span><span>X</span><span>Z</span><span>B</span>
            </div>
            <div class="loc-row">
                <span class="mon-label">IN</span>
                <span class="mon-value" id="disp-Xin">--</span>
                <span class="mon-value" id="disp-Zin">--</span>
                <span class="mon-value" id="disp-Bin">--</span>
            </div>
            <div class="loc-row">
                <span class="mon-label">OUT</span>
                <span class="mon-value" id="disp-Xout">--</span>
                <span class="mon-value" id="disp-Zout">--</span>
                <span class="mon-value" id="disp-Bout">--</span>
            </div>
        </div>
        <div class="cmd-row" style="margin-top: 14px; border-bottom: none;">
            <span class="mon-label">Mode Crane &amp; Shuttle</span>
            <span class="mon-value" id="disp-ModeCraneShuttle" style="color:#58a6ff">--</span>
        </div>
    </div>

</div>

<p id="last-update" style="margin-top:16px;font-size:0.75rem;color:#484f58;">--</p>

<!-- ═══════════════════════════════════════════════════════ -->
<!--  STYLES                                                -->
<!-- ═══════════════════════════════════════════════════════ -->
<style>
    /* ── top header ── */
    .top-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 20px;
        gap: 12px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #58a6ff;
        letter-spacing: 1.5px;
        margin: 0;
    }

    .section-title {
        font-size: 11px;
        font-weight: 600;
        color: #64748b;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin: 24px 0 10px 0;
    }

    /* ── PLC chips ── */
    .plc-row {
        display: flex;
        gap: 12px;
    }

    .plc-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 20px;
        padding: 6px 16px;
        font-size: 0.85rem;
    }

    .dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .dot.on  { background: #3fb950; box-shadow: 0 0 6px #3fb950; }
    .dot.off { background: #f85149; }

    .plc-text { font-size: 0.8rem; }

    /* ── monitor grid ── */
    .mon-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
    }

    /* ── bottom grid: 3 cột cố định ngang nhau, chiều cao bằng nhau ── */
    .bottom-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 14px;
        align-items: stretch;
    }

    .bottom-grid > .mon-card {
        height: 100%;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
    }


    .mon-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 10px;
        padding: 14px 18px;
    }

    .mon-title {
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #8b949e;
        margin-bottom: 10px;
        border-bottom: 1px solid #21262d;
        padding-bottom: 6px;
    }

    .mon-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 5px 0;
        font-size: 0.875rem;
        border-bottom: 1px solid #21262d;
    }
    .mon-row:last-child { border-bottom: none; }

    .mon-label { color: #8b949e; }

    .mon-value {
        font-weight: 600;
        color: #e6edf3;
        font-family: 'Courier New', monospace;
    }

    .barcode-plc1 { color: #38bdf8; }
    .barcode-plc2 { color: #a78bfa; }

    /* ── badge trạng thái ── */
    .badge {
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    .badge-free { background: #0d4429; color: #3fb950; }
    .badge-busy { background: #3d2e00; color: #e3b341; }
    .badge-error{ background: #3d1a1a; color: #f85149; }
    .badge-idle { background: #21262d; color: #8b949e; }

    /* ── controls ── */
    .cmd-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 6px 0;
        border-bottom: 1px solid #21262d;
        margin-bottom: 10px;
    }

    .cmd-select {
        flex: 1;
        padding: 8px 10px;
        border-radius: 7px;
        border: 1px solid #334155;
        background: #0f172a;
        color: #e2e8f0;
        font-size: 13px;
        font-weight: 600;
        outline: none;
        cursor: pointer;
        transition: border-color .2s;
    }
    .cmd-select:focus { border-color: #3b82f6; }
    .cmd-select option { background: #0f172a; }

    .loc-table { display: flex; flex-direction: column; gap: 6px; }

    .loc-header { font-size: 11px; font-weight: 600; color: #64748b; }

    .loc-row {
        display: grid;
        grid-template-columns: 42px 1fr 1fr 1fr;
        gap: 8px;
        align-items: center;
    }

    input[type=number] {
        width: 100%;
        padding: 7px 10px;
        border-radius: 7px;
        border: 1px solid #334155;
        background: #0f172a;
        color: white;
        font-size: 13px;
        box-sizing: border-box;
        outline: none;
        transition: border-color .2s;
    }
    input[type=number]:focus { border-color: #3b82f6; }

    .btn {
        border: none;
        padding: 9px 18px;
        border-radius: 7px;
        color: white;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        transition: opacity .15s, transform .1s;
    }
    .btn:hover  { opacity: 0.85; }
    .btn:active { transform: scale(0.96); }
    .btn-blue   { background: #2563eb; }
</style>

<!-- ═══════════════════════════════════════════════════════ -->
<!--  SCRIPT                                                -->
<!-- ═══════════════════════════════════════════════════════ -->
<script>

    function barcodeBadge(ok, ng) {
        if (ok) return '<span class="badge badge-free">OK</span>';
        if (ng) return '<span class="badge badge-error">NG</span>';
        return '<span class="badge badge-idle">--</span>';
    }

    function badge(busy, free, error) {
        if (error) return '<span class="badge badge-error">ERROR</span>';
        if (busy)  return '<span class="badge badge-busy">BUSY</span>';
        if (free)  return '<span class="badge badge-free">FREE</span>';
        return '<span class="badge badge-idle">IDLE</span>';
    }

    function boolBadge(val, trueLabel, trueClass, falseLabel) {
        if (val) return `<span class="badge ${trueClass}">${trueLabel}</span>`;
        return `<span class="badge badge-idle">${falseLabel}</span>`;
    }

    function setDot(dotId, textId, connected) {
        const dot  = document.getElementById(dotId);
        const text = document.getElementById(textId);
        dot.className  = 'dot ' + (connected ? 'on' : 'off');
        text.textContent = connected ? 'Connected' : 'Offline';
        text.style.color = connected ? '#3fb950' : '#f85149';
    }

    function setText(id, val) {
        const el = document.getElementById(id);
        if (!el) return;
        // Hiển thị số 0 đúng — chỉ ẩn khi null hoặc undefined
        el.textContent = (val !== null && val !== undefined) ? val : '--';
    }

    function setHtml(id, html) {
        const el = document.getElementById(id);
        if (el) el.innerHTML = html;
    }

    async function updateStatus() {
        try {
            const data = await fetch('/status').then(r => r.json());

            // PLC connection
            setDot('dot1', 'plc1-text', data.plc1);
            setDot('dot2', 'plc2-text', data.plc2);

            // Barcode
            setText('barcode1', data.barcode1 || '---');
            setHtml('barcode1-status', barcodeBadge(data.barcodeOk1, data.barcodeNg1));

            setText('barcode2', data.barcode2 || '---');
            setHtml('barcode2-status', barcodeBadge(data.barcodeOk2, data.barcodeNg2));

            // Crane 1
            const c1 = data.crane1 || {};
            setText('crane1-x',   c1.x);
            setText('crane1-z',   c1.z);
            setHtml('crane1-state', badge(c1.busy, c1.free, c1.error));
            setText('crane1-err', c1.error ? c1.errorCode : 'OK');

            // Crane 2
            const c2 = data.crane2 || {};
            setText('crane2-x',   c2.x);
            setText('crane2-z',   c2.z);
            setHtml('crane2-state', badge(c2.busy, c2.free, c2.error));
            setText('crane2-err', c2.error ? c2.errorCode : 'OK');

            // Shuttle 1
            const s1 = data.shuttle1 || {};
            setText('shuttle1-x',   s1.x);
            setText('shuttle1-z',   s1.z);
            setText('shuttle1-b',   s1.b);
            setHtml('shuttle1-state', badge(s1.busy, s1.free, s1.error));
            setText('shuttle1-pin', s1.pin);

            // Shuttle 2
            const s2 = data.shuttle2 || {};
            setText('shuttle2-x',   s2.x);
            setText('shuttle2-z',   s2.z);
            setText('shuttle2-b',   s2.b);
            setHtml('shuttle2-state', badge(s2.busy, s2.free, s2.error));
            setText('shuttle2-pin', s2.pin);

            // System State PLC1
            const sy1 = data.system1 || {};
            setHtml('sys1-mode', boolBadge(sy1.auto,    'AUTO',    'badge-free', 'MANUAL'));
            setHtml('sys1-run',  boolBadge(sy1.running, 'RUNNING', 'badge-free', 'STOPPED'));
            setHtml('sys1-stop', boolBadge(sy1.stop,    'STOP',    'badge-busy', 'OK'));
            setHtml('sys1-err',  boolBadge(sy1.error,   'ERROR',   'badge-error','OK'));
            setText('sys1-code', sy1.errorCode);

            // System State PLC2
            const sy2 = data.system2 || {};
            setHtml('sys2-mode', boolBadge(sy2.auto,    'AUTO',    'badge-free', 'MANUAL'));
            setHtml('sys2-run',  boolBadge(sy2.running, 'RUNNING', 'badge-free', 'STOPPED'));
            setHtml('sys2-stop', boolBadge(sy2.stop,    'STOP',    'badge-busy', 'OK'));
            setHtml('sys2-err',  boolBadge(sy2.error,   'ERROR',   'badge-error','OK'));
            setText('sys2-code', sy2.errorCode);

            // Last Location Cmd
            const loc = data.lastLocation || {};
            
            let cmdText = "--";
            if (loc.commandType === 1) cmdText = "1 — Nhập Pallet";
            else if (loc.commandType === 2) cmdText = "2 — Xuất Pallet";
            else if (loc.commandType === 3) cmdText = "3 — Chuyển Pallet";
            
            setText('disp-CommandType', cmdText);
            setText('disp-Xin', loc.xin);
            setText('disp-Zin', loc.zin);
            setText('disp-Bin', loc.bin);
            setText('disp-Xout', loc.xout);
            setText('disp-Zout', loc.zout);
            setText('disp-Bout', loc.bout);

            setText('disp-ModeCraneShuttle', data.modeCraneShuttle);

            document.getElementById('last-update').textContent =
                'Cập nhật lúc: ' + new Date().toLocaleTimeString('vi-VN');

        } catch (e) {
            console.warn('Status fetch failed:', e);
        }
    }

    setInterval(updateStatus, 1000);
    updateStatus();

</script>