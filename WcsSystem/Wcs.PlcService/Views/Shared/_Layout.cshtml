<!DOCTYPE html>
<html>
<head>

    <title>WCS SYSTEM</title>

    <style>

        body {
            margin: 0;
            font-family: Segoe UI;
            background: #0f172a;
            color: white;
        }

        .header {
            height: 60px;
            background: #020617;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            border-bottom: 1px solid #1e293b;
        }

        .header-title {
            font-weight: 600;
        }

        .content {
            padding: 30px;
        }

        /* GRID */

        .grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 20px;
        }

        .card {
            background: #020617;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid #1e293b;
        }

        .card-title {
            font-size: 14px;
            color: #94a3b8;
        }

        .card-value {
            font-size: 26px;
            margin-top: 10px;
        }

        /* BUTTON */

        .btn {
            border: none;
            padding: 10px 16px;
            border-radius: 6px;
            color: white;
            cursor: pointer;
            margin-right: 8px;
        }

        .btn-green {
            background: #22c55e;
        }

        .btn-red {
            background: #ef4444;
        }

        .btn-blue {
            background: #3b82f6;
        }

        .btn-yellow {
            background: #eab308;
        }

        .btn:hover {
            opacity: 0.85;
        }

        /* INPUT */

        input {
            padding: 8px;
            border-radius: 6px;
            border: 1px solid #334155;
            background: #020617;
            color: white;
        }

        .input-row {
            display: flex;
            gap: 10px;
            margin-bottom: 12px;
        }

        /* STATUS */

        .green {
            color: #22c55e;
        }

        .red {
            color: #ef4444;
        }

        .barcode {
            font-size: 32px;
            margin-top: 10px;
        }

    </style>

</head>

<body>

    <div class="header">

        <div class="header-title">
            Warehouse Control System
        </div>

        <div>
            IPC SERVER
        </div>

    </div>

    <div class="content">

        @RenderBody()

    </div>

</body>
</html>